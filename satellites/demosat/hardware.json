{
  "portMap": {
    "0x01": { "command": "ping", "type": "diagnostic" },
    "0x10": { "command": "solar_panel", "target": "solar_panel" },
    "0x20": { "command": "antenna_gimbal", "target": "antenna" },
    "0x30": { "command": "subsystem_ctrl", "target": "adcs" },
    "0x40": { "command": "transponder_ctrl", "target": "transponder" },
    "0xE0": { "command": "auth_change", "target": "auth" },
    "0xF0": { "command": "firmware_upload", "target": "obc" },
    "0xFF": { "command": "obc_reboot", "target": "obc" }
  },

  "hardware": {
    "solar_panel": {
      "defaults": { "angle": 90, "power": 4.2 },
      "specs": {
        "maxPower": 4.2,
        "motorSpeed": 3,
        "optimalAngle": 90
      }
    },
    "battery": {
      "defaults": { "level": 100 },
      "specs": { "capacity": 100 }
    },
    "antenna": {
      "defaults": { "az": 180, "el": 45 },
      "specs": {
        "type": "patch",
        "beamwidth": 25,
        "motorSpeed": 2
      }
    },
    "comm": {
      "defaults": { "status": "CONNECTED" },
      "specs": {}
    },
    "transponder": {
      "defaults": { "state": true },
      "specs": {}
    },
    "adcs": {
      "defaults": { "roll": 0, "pitch": 0, "yaw": 0, "stabilization": true, "mode": "sun-track" },
      "specs": {
        "mass": 4,
        "momentOfInertia": 0.02
      }
    },
    "obc": {
      "defaults": { "uptime": 0, "temp": 22, "rebooting": false },
      "specs": {
        "rebootTime": 20,
        "maxTemp": 85
      }
    },
    "auth": {
      "defaults": { "key": "DEFAULT" },
      "specs": {}
    }
  }
}
